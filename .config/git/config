[user]
	name = Oliver Fitzgerald
	email = ofitzgerald15@gmail.com
[diff]
	tool = nvimdiff
[difftool]
	prompt = false
[merge]
	tool = vimdiff
    keepBackup = false
[safe]
	directory = /usr/local/mark
	directory = /home/guts/documents/college/year-4-sem-1/cs4298-theory-and-practice-of-software-design/cafe-pos-and-delivery
[core]
    whitespace = error
	editor = nvim

[init]
    defaultBranch = main

[url "ssh://git@github.com:Oliver-Fitzgerald/"]
    insteadof = "of:"

[status]
    branch = true
    showStash = true

[pager]
    diff = diff-so-fancy

[diff-so-fancy]
    markEmptyLines = false

[color "diff"]
    meta = black bold
    frag = magenta
    context = white
    whitespace = yellow reverse
    old = red

[interactive]
    diffFilter = diff-so-fancy --patch
    singleKey = true

[push]
    autoSetupRemote = true
    default = current

[pull]
    default = current
    rebase = true

[rebase]
    autoStash = true
    missingCommitsCheck = warn



